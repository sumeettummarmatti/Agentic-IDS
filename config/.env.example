# Groq API
GROQ_API_KEY=...

# Ollama Configuration
OLLAMA_MODEL=deepseek-v3:7b
OLLAMA_BASE_URL=http://localhost:11434

# LLM Council
LLM_COUNCIL_USE_LOCAL=true
LLM_COUNCIL_TIMEOUT=30

# Data Paths
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_SYNTHETIC_PATH=data/synthetic

# Model Paths
MODEL_CHECKPOINT_PATH=models/checkpoints
MODEL_TRAINED_PATH=models/trained

# Detector Config
DETECTOR_MODEL_TYPE=xgboost
DETECTOR_THRESHOLD=0.5
DETECTOR_ENSEMBLE=true

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/
